#!/usr/bin/env php
<?php

declare(strict_types=1);

use WpPluginInsights\RunnerDummy\Application;

$autoload = __DIR__ . '/../vendor/autoload.php';

if (!is_file($autoload)) {
    fwrite(STDERR, "Missing Composer autoload file. Run: composer install\n");
    exit(1);
}

require $autoload;

$application = new Application();
$application->run();
